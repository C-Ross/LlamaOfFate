# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# Build output
bin/

# Action binaries and executables
/action-parser
/llm-scene-loop
/fate-guided-scene
/main
/scene-generator
/scenario-generator
/scenario-walkthrough
/server
/mcpserver
/cli
/llmeval-tracker

# Configuration files with sensitive information
*.local.yaml

# Session logs folder (auto-generated during gameplay)
sessions/

# Logs logs folder
logs/

# Web UI
web/node_modules/
web/dist/*
!web/dist/.keep

# Playwright MCP session artifacts
.playwright-mcp/

# LLM eval tracking results (local accumulation)
test/llmeval/results.jsonl
